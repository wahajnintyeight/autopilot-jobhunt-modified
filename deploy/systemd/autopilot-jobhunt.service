[Unit]
Description=autopilot-jobhunt scheduler service
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/autopilot-jobhunt
Environment=AUTOPILOT_LOG_FILE=/opt/autopilot-jobhunt/scan.log
Environment=PYTHONIOENCODING=utf-8
ExecStart=/opt/autopilot-jobhunt/.venv/bin/autopilot service
Restart=always
RestartSec=10
Nice=10

[Install]
WantedBy=multi-user.target
